{
  "description": "Talgent runtime hook telemetry for plugin and skill usage.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/record-skill-call.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
